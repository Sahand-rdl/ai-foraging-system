
# Database
DATABASE_URL=sqlite:///./database.db

# Papers Storage - where PDFs and extracted files are saved
PAPERS_STORAGE_PATH=~/Documents/AIForaging/papers

# Microservice URLs
SEMANTIC_SEARCH_URL=http://localhost:8001
LLM_SERVICE_URL=http://localhost:8001

# Feature Flags - set to true when services are ready
SEMANTIC_SEARCH_ENABLED=true
LLM_ENABLED=true

# Optional API Keys
OPENAI_API_KEY=

# Server Settings
HOST=127.0.0.1
PORT=8000
DEBUG=true
